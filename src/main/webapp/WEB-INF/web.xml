<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>CollabDocs</display-name>
    <description>Plateforme d'édition collaborative en temps réel — V2</description>

    <!-- =========================================================
         SESSION
    ========================================================= -->
    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
    </session-config>

    <!-- =========================================================
         FILTRE D'AUTHENTIFICATION
    ========================================================= -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.collabdocs.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/editor/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/home</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/document/*</url-pattern>
    </filter-mapping>

    <!-- =========================================================
         SERVLETS
    ========================================================= -->

    <!-- Servlet d'accueil -->
    <servlet>
        <servlet-name>IndexServlet</servlet-name>
        <servlet-class>com.collabdocs.controller.IndexServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>IndexServlet</servlet-name>
        <url-pattern>/index.jsp</url-pattern>
    </servlet-mapping>

    <!-- Login -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.collabdocs.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Register -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.collabdocs.controller.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- Logout -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.collabdocs.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Home -->
    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>com.collabdocs.controller.HomeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>

    <!-- Document CRUD (wildcard — doit être APRÈS les mappings exacts /document/*) -->
    <servlet>
        <servlet-name>DocumentServlet</servlet-name>
        <servlet-class>com.collabdocs.controller.DocumentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DocumentServlet</servlet-name>
        <url-pattern>/document/*</url-pattern>
    </servlet-mapping>

    <!-- DocumentUnlockServlet — mapping exact, prioritaire sur /document/* -->
    <servlet>
        <servlet-name>DocumentUnlockServlet</servlet-name>
        <servlet-class>com.collabdocs.controller.DocumentUnlockServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DocumentUnlockServlet</servlet-name>
        <url-pattern>/document/unlock</url-pattern>
    </servlet-mapping>

    <!-- RestoreServlet — mapping prioritaire sur /document/* pour les chemins restore -->
    <servlet>
        <servlet-name>RestoreServlet</servlet-name>
        <servlet-class>com.collabdocs.controller.RestoreServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RestoreServlet</servlet-name>
        <url-pattern>/document/restore</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RestoreServlet</servlet-name>
        <url-pattern>/document/restore/*</url-pattern>
    </servlet-mapping>

    <!-- Editor -->
    <servlet>
        <servlet-name>EditorServlet</servlet-name>
        <servlet-class>com.collabdocs.controller.EditorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditorServlet</servlet-name>
        <url-pattern>/editor/*</url-pattern>
    </servlet-mapping>
    <!-- Accès par lien partagé -->
    <servlet-mapping>
        <servlet-name>EditorServlet</servlet-name>
        <url-pattern>/d/*</url-pattern>
    </servlet-mapping>

    <!-- Admin -->
    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>com.collabdocs.controller.AdminServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/admin</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/admin/*</url-pattern>
    </servlet-mapping>

    <!-- =========================================================
         PAGES D'ERREUR
    ========================================================= -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>403</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>

    <!-- =========================================================
         WELCOME FILES
    ========================================================= -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

</web-app>
